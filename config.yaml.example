# Python CLI and library configuration
# Used by: truenas-monitor CLI, truenas_storage_monitor library
# Copy to config.yaml and update values.
#
# Go monitor/API use a different schema — see config.go.example and
# docs/config-compatibility.md.

# OpenShift/Kubernetes configuration (required)
openshift:
  kubeconfig: ~/.kube/config
  namespace: democratic-csi

# TrueNAS configuration
truenas:
  url: https://truenas.example.com
  username: ${TRUENAS_USERNAME}
  password: ${TRUENAS_PASSWORD}
  insecure: false
  # ca_file: /etc/truenas-monitor/truenas-ca.pem
  timeout: 30

# Monitoring configuration (required)
monitoring:
  orphan_check_interval: 1h
  orphan_threshold: 24h
  snapshot:
    max_age: 30d
    max_count: 50
    check_interval: 6h
  storage:
    pool_warning_threshold: 80
    pool_critical_threshold: 90
    volume_warning_threshold: 85
    volume_critical_threshold: 95
    max_overcommit_ratio: 2.0

# Alerts (partial — not all channels wired in baseline)
alerts:
  enabled: true
  slack:
    webhook_url: ${SLACK_WEBHOOK_URL}
    channel: "#storage-alerts"

# Logging (example keys; limited use in baseline library)
logging:
  level: info
  format: json
  output: stdout

# --- Planned sections below: NOT read by baseline Python library ---
# Kept as roadmap reference only. See docs/config-compatibility.md.

